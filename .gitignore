__pycache__/
*.pyc
.venv/
.DS_Store

# Downloaded/generated datasets are large and reproducible from download.py + sampler.py + attack_generator.py — never commit
datasets/FUNSD/
datasets/CORD/
datasets/SROIE/
datasets/FigStep/
datasets/DocLayNet/

# sampled_images.json, doclaynet_sampled_images.json, and attack_metadata.json
# ARE committed (frozen, small, define the reproducible sample). datasets/attacks/
# and datasets/doclaynet_attacks/ ARE ALSO committed, unlike the raw datasets
# above — attack_generator.py's font rendering is macOS-path-dependent, so
# those images are NOT perfectly reproducible on another machine.

typographic/outputs/
*.pkl
*.egg-info/

# Adversarial module: unlike Typographic, attack_generator.py here uses only
# procedural drawing (no system fonts), so patched images and candidate crops
# ARE perfectly reproducible cross-platform from committed code + committed
# clean images + fixed seed — no font-portability exception needed.
# adversarial/attack_metadata.json IS committed (frozen, small, defines the
# reproducible random choices), same reasoning as typographic's.
datasets/adversarial/attacks/
datasets/adversarial/candidates/
datasets/adversarial/candidate_labels.csv
datasets/adversarial/candidate_metadata.json
adversarial/outputs/
